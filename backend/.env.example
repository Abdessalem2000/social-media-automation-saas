# ===========================================
# Social Media Automation - Environment Variables
# ===========================================

# Server Configuration
NODE_ENV=development
PORT=3001
TZ=UTC

# Frontend Configuration
FRONTEND_URL=http://localhost:8002
CORS_ORIGIN=http://localhost:8002

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/social-media-automation
DB_NAME=social_media_automation

# JWT Configuration - CRITICAL SECURITY
JWT_ACCESS_SECRET=your-super-secret-access-key-change-this-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Social Media API Keys (Optional for MVP)
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
INSTAGRAM_CLIENT_ID=your-instagram-client-id
INSTAGRAM_CLIENT_SECRET=your-instagram-client-secret
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TIKTOK_CLIENT_ID=your-tiktok-client-id
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@socialmediaautomation.com

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,mp4,mov

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# Scheduler Configuration
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=UTC
SCHEDULER_CONCURRENCY_LIMIT=5

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

# Security Configuration
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret-change-this-in-production
COOKIE_SECURE=false
COOKIE_SAME_SITE=strict

# Performance Configuration
COMPRESSION_ENABLED=true
TRUST_PROXY=false

# Monitoring & Health Checks
HEALTH_CHECK_ENABLED=true
METRICS_ENABLED=false

# Development Only
DEBUG=app:*
MOCK_SOCIAL_MEDIA_APIS=true
